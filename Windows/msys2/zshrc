# Minimal MSYS2 zsh config for Windows
# Designed for MSYS2 UCRT64/MINGW64 with default home (/home/username).
# Dotfiles repo is always located at $USERPROFILE/dotfiles on Windows.

# ---------------------------------------------------------------------------
# Dotfiles path (Windows home -> POSIX path via cygpath)
# ---------------------------------------------------------------------------
export DOTFILES="$(cygpath -u "$USERPROFILE")/dotfiles"

# ---------------------------------------------------------------------------
# Powerlevel10k instant prompt
# Should stay close to the top. Code that may require console input must be
# above this block; everything else may be below.
# ---------------------------------------------------------------------------
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# ---------------------------------------------------------------------------
# Shell options
# ---------------------------------------------------------------------------
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_SPACE
setopt SHARE_HISTORY
setopt AUTO_CD
setopt CORRECT

# ---------------------------------------------------------------------------
# History
# ---------------------------------------------------------------------------
export HISTFILE=~/.zsh_history
export HISTSIZE=10000
export SAVEHIST=10000

# ---------------------------------------------------------------------------
# PATH
# Priority: dotfiles/bin > ~/.local/bin > everything else (incl. Windows PATH)
# cygpath converts Windows $USERPROFILE to a POSIX path that MSYS2 understands.
# typeset -gU deduplicates the array (important with inherited Windows PATH).
# ---------------------------------------------------------------------------
path=(
  "$DOTFILES/bin"
  "$HOME/.local/bin"
  $path
)
typeset -gU path

# ---------------------------------------------------------------------------
# Editors
# ---------------------------------------------------------------------------
export EDITOR='vim'
export VISUAL='vim'
if command -v nvim > /dev/null 2>&1; then
  export EDITOR='nvim'
  export VISUAL='nvim'
fi

# ---------------------------------------------------------------------------
# Key bindings
# ---------------------------------------------------------------------------
# Fix Home / End keys (MSYS2 terminals send different sequences)
bindkey '^[[1~' beginning-of-line   # Home
bindkey '^[[4~' end-of-line         # End
bindkey '^[[H'  beginning-of-line   # Home (alternate)
bindkey '^[[F'  end-of-line         # End (alternate)
# Fix Delete key (without this it types ~ instead of deleting)
bindkey '^[[3~' delete-char

# ---------------------------------------------------------------------------
# Completion
# ---------------------------------------------------------------------------
autoload -Uz compinit && compinit

# ---------------------------------------------------------------------------
# Prompt — powerlevel10k (installed by setup.sh)
# ---------------------------------------------------------------------------
[[ -f ~/powerlevel10k/powerlevel10k.zsh-theme ]] && \
  source ~/powerlevel10k/powerlevel10k.zsh-theme

# ---------------------------------------------------------------------------
# fzf
# Scoop installs fzf to the Windows PATH (accessible via inherited PATH).
# ~/.fzf.zsh (key bindings + completion) can be generated by:
#   $DOTFILES/fzf/.fzf.zsh or fzf --zsh
# ---------------------------------------------------------------------------
if [[ -f ~/.fzf.zsh ]]; then
  source ~/.fzf.zsh
elif command -v fzf > /dev/null 2>&1; then
  source <(fzf --zsh)
fi

if command -v fzf > /dev/null 2>&1; then
  export FZF_DEFAULT_OPTS='--layout=reverse'
  # prefer fd over find for fzf file listing
  if command -v fd > /dev/null 2>&1; then
    export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude={.git,.idea,.sass-cache,node_modules,build,.rustup,.cache}'
  fi
  # preview with bat if available
  if command -v bat > /dev/null 2>&1; then
    alias fp="fzf --preview 'bat --style=numbers --color=always --line-range :500 {}'"
  fi
fi

# ---------------------------------------------------------------------------
# zoxide (smart cd)
# ---------------------------------------------------------------------------
if command -v zoxide > /dev/null 2>&1; then
  eval "$(zoxide init zsh)"
fi

# ---------------------------------------------------------------------------
# bat (cat replacement)
# ---------------------------------------------------------------------------
if command -v bat > /dev/null 2>&1; then
  export BAT_STYLE="changes,header,numbers,snip"
  alias cat='bat -p'
fi

# ---------------------------------------------------------------------------
# Common aliases
# ---------------------------------------------------------------------------
alias l='ls -lhA'
alias lr='l -RA'
alias lt='l -t'
alias h='history | tac | fzf'
alias grep='grep -i'
alias mmv='noglob zmv -W'

# editors
alias nv='nvim'

# navigation / misc
alias epoch='date +%s'
alias today='date +%Y%m%d'
alias now="date '+%Y-%m-%d %H:%M:%S'"
alias myip='curl ipinfo.io/json'

# python
alias py='python'
alias py3='python3'
alias serve='python3 -m http.server'
alias pip='python -m pip'

# ---------------------------------------------------------------------------
# Windows interop
# (this file is MSYS2-only so no uname guard needed)
# ---------------------------------------------------------------------------
alias open='explorer.exe'
alias clip='clip.exe'

# dos2unix self-made fallback if package not installed
if ! command -v dos2unix > /dev/null 2>&1; then
  alias dos2unix="sed -i 's/\r$//'"
fi

# ---------------------------------------------------------------------------
# Git aliases and functions
# ---------------------------------------------------------------------------
alias gg='git grep -i'
alias gitc='git-crypt'
alias lg='lazygit'

# git worktree helpers
# Usage: gwa <branch-name>
gwa() {
  local branch_name="$1"
  local append="$(printf '%s' "$branch_name" | tr '/' '_')"
  local repo_name=$(basename "$(git rev-parse --show-toplevel)")
  git worktree add "../${repo_name}-${append}" "${branch_name}"
}
# Usage: gwj (pick from list with fzf)
gwj() {
  local target=$(git worktree list | fzf | awk '{print $1}')
  [ -n "$target" ] && cd "$target"
}
alias gwb='git worktree add -b'
alias gwr='git worktree remove'
alias gwl='git worktree list --porcelain | grep "^branch" | cut -d " " -f 2 | sed s@refs/heads/@@g'
alias gwp='git worktree prune'
alias gwre='git worktree repair'

# ---------------------------------------------------------------------------
# tmux aliases (tmux works fine on MSYS2)
# ---------------------------------------------------------------------------
alias main='tmux attach -t main || tmux new -s main'
alias work='tmux attach -t work || tmux new -s work'
alias tm_kill='tmux kill-session -t'

# ---------------------------------------------------------------------------
# mkcd — mkdir + cd in one step
# ---------------------------------------------------------------------------
mkcd() {
  if [[ -z "$1" ]]; then
    local last_cmd="$(fc -ln 0 | tail -n1)"
    if [[ "$last_cmd" =~ ^cd\ .+ ]]; then
      local dir="$(printf '%s' "${last_cmd}" | sed 's/cd \(.*\)/\1/')"
      mkdir -p "$dir" && cd "$dir" || return 1
    else
      echo "Usage: mkcd <dir>  (or run after a failed 'cd <dir>')"
    fi
  else
    mkdir -p "$1" && cd "$1" || return 1
  fi
}

# ---------------------------------------------------------------------------
# dotup — pull latest dotfiles
# ---------------------------------------------------------------------------
dotup() {
  (
    cd "$DOTFILES" || return 1
    [[ "$(git rev-parse --abbrev-ref HEAD)" == 'main' ]] \
      && git pull --rebase --autostash origin main \
      || echo "Error: not on 'main' branch, skipping pull."
  )
}

# ---------------------------------------------------------------------------
# Load local overrides if present (machine-specific tweaks)
# ---------------------------------------------------------------------------
[[ -f ~/.zsh_custom ]] && source ~/.zsh_custom

# ---------------------------------------------------------------------------
# p10k config (reuse existing dotfiles config)
# ---------------------------------------------------------------------------
[[ -f ~/.p10k.zsh ]] && source ~/.p10k.zsh
